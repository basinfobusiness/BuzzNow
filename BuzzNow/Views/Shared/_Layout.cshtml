<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BuzzNow</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BuzzNow.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD" crossorigin="anonymous">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">BuzzNow</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Special Event</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            <ul class="nav nav-pills">
                <li class="nav-item dropdown">
                    <a class="nav-link text-uppercase dropdown-toggle" href="#" data-bs-toggle="dropdown">football</a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item text-capitalize">international friendlies</a></li>
                        <li><a class="dropdown-item text-capitalize">worldcup</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link text-uppercase dropdown-toggle" href="#" data-bs-toggle="dropdown">basketball</a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item">NBA</a></li>
                        <li><a class="dropdown-item">NCAA Division 1 National Championship</a></li>
                        <li><a class="dropdown-item">KBL</a></li>
                    </ul>
                </li>
                <li class="nav-item"><a class="nav-link text-uppercase">baseball</a></li>
                <li class="nav-item"><a class="nav-link text-uppercase">tennis</a></li>
                <li class="nav-item"><a class="nav-link text-uppercase">soccer</a></li>
                <li class="nav-item"><a class="nav-link text-uppercase">golf</a></li>
                <li class="nav-item"><a class="nav-link text-uppercase">hockey</a></li>
                <li class="nav-item dropdown">
                    <a class="nav-link text-uppercase dropdown-toggle" href="#" data-bs-toggle="dropdown">mma</a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">UFC Fight Night</a></li>
                    </ul>
                </li>
                <li class="nav-item"><a class="nav-link text-uppercase">boxing</a></li>
                <li class="nav-item"><a class="nav-link text-uppercase active">esports</a></li>
            </ul>
            @RenderBody()
        </main>
    </div>

    <div class="container-fluid">
       <div class="text-bg-dark p-3">
            <div class="row">
                <div class="col">
                    <h6>BuzzNow</h6>
                    <p>Your ultimate sports and entertainment arena.</p>
                    <p class="text-capitalize">our newsletter</p>
                    <div class="input-group">
                        <input type="email" class="form-control" placeholder="Enter your email" aria-label="Enter your email" aria-describedby="button-subscribe">
                        <button class="btn btn-outline-secondary" type="button"><i class="bi bi-send"></i></button>
                    </div>
                </div>
                <div class="col">
                    <h6>Popular News</h6>
                    <div class="row">
                        <div class="col">
                            <img src="~/images//BUZZNOW-FOOTER-1.png" alt="hockey" class="img-thumbnail h-75" title="hockey club" />
                        </div>
                        <div class="col">
                            <h6>Hockey</h6>
                            <p>2026 Stanley Cup Finals: A thrilling showdown between the Colorado Avalanche and the Florida Panthers.</p>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <h6>Other News</h6>
                </div>
                <div class="col">
                    <h6>Twitter</h6>
                </div>
            </div>
       </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BuzzNow - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
